{
  "name": "available-runner-action",
  "version": "1.0.0",
  "description": "GitHub Action to detect self-hosted runner availability with automatic fallback to GitHub-hosted runners",
  "private": true,
  "scripts": {
    "build": "ncc build src/index.ts -o dist --license licenses.txt --quiet",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "@vercel/ncc": "^0.38.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4",
    "typescript": "^5.4.5"
  }
}
